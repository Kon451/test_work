# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EVENTS_EXCHANGE=events.exchange
RABBITMQ_CONSUMER_QUEUE=consumer.queue
RABBITMQ_TELEGRAM_QUEUE=telegram.queue
RABBITMQ_DLX=events.dlx
RABBITMQ_RETRY_LIMIT=3

# Producer
PRODUCER_HTTP_PORT=3000

# Consumer
CONSUMER_HTTP_PORT=3001

# Telegram Notifier
TELEGRAM_HTTP_PORT=3002
TELEGRAM_BOT_TOKEN=replace_with_token_from_BotFather
TELEGRAM_CHAT_ID=replace_with_your_chat_id
