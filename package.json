{
  "name": "rabbitmq-telegram-microservices",
  "version": "1.0.0",
  "private": true,
  "description": "Микросервисы Nest.js + RabbitMQ + Telegram Bot API",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start:producer": "npm run start:dev -w @app/producer",
    "start:consumer": "npm run start:dev -w @app/consumer",
    "start:telegram": "npm run start:dev -w @app/telegram-notifier"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
